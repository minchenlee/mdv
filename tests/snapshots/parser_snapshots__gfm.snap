---
source: tests/parser_snapshots.rs
expression: blocks
---
- Blockquote:
    - Paragraph:
        - Text: A blockquote
        - Text: "\n"
        - Text: with two lines.
- List:
    ordered: false
    items:
      - task: ~
        blocks:
          - Paragraph:
              - Text: alpha
      - task: ~
        blocks:
          - Paragraph:
              - Text: beta
          - List:
              ordered: false
              items:
                - task: ~
                  blocks:
                    - Paragraph:
                        - Text: nested
      - task: true
        blocks:
          - Paragraph:
              - Text: done
      - task: false
        blocks:
          - Paragraph:
              - Text: todo
- List:
    ordered: true
    items:
      - task: ~
        blocks:
          - Paragraph:
              - Text: one
      - task: ~
        blocks:
          - Paragraph:
              - Text: two
- CodeBlock:
    lang: rust
    code: "fn main() { println!(\"hi\"); }\n"
    spans:
      - range:
          start: 0
          end: 2
        style: Keyword
      - range:
          start: 3
          end: 7
        style: Function
      - range:
          start: 7
          end: 8
        style: Punctuation
      - range:
          start: 8
          end: 9
        style: Punctuation
      - range:
          start: 10
          end: 11
        style: Punctuation
      - range:
          start: 12
          end: 19
        style: Function
      - range:
          start: 19
          end: 20
        style: Function
      - range:
          start: 20
          end: 21
        style: Punctuation
      - range:
          start: 21
          end: 25
        style: String
      - range:
          start: 25
          end: 26
        style: Punctuation
      - range:
          start: 26
          end: 27
        style: Punctuation
      - range:
          start: 28
          end: 29
        style: Punctuation
- Table:
    headers:
      - - Text: Col A
      - - Text: Col B
    rows:
      - - - Text: "1"
        - - Text: "2"
      - - - Text: "3"
        - - Text: "4"
- Rule
